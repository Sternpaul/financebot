# ===== SHARED =====
# Set the time zone for your scheduled jobs and logging
TIMEZONE=CET
REDIS_URL=redis://redis:6379
# Logging level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# ===== BOT ONLY =====
DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=123456789012345678
# The ID of your guild/server for syncing application commands locally
DISCORD_GUILD_ID=123456789012345678 

# ===== DATABASE (Supabase Postgres) =====
# Connection string from Supabase dashboard (Settings -> Database -> Connection string -> URI)
SUPABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ===== WORKER ONLY =====
# Scheduler Configuration
MORNING_REPORT_TIME=07:30
MARKET_HOURS_START=09:00
MARKET_HOURS_END=17:30

# Market Data APIs
MASSIVE_API_KEY=your_massive_key
POLYGON_API_KEY=your_polygon_key
HYPERLIQUID_API_KEY=your_hyperliquid_key
FINNHUB_API_KEY=your_finnhub_key

# AI & Embedding
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx
LLM_MODEL=nvidia/nemotron-3-ultra:free
LLM_FALLBACK_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,google/gemma-4-31b-it:free,openrouter/owl-alpha

# Cron Job Intervals
CRON_ALERTS_INTERVAL_MINUTES=1
CRON_NEWS_INTERVAL_MINUTES=1
CRON_TELEGRAM_BACKUP_HOURS=1
CRON_BRAIN_SYNTHESIS_MINUTES=30
CRON_BRAIN_COMPACTION_HOURS=24

# RSSHub Twitter Authentication (Burner account recommended)
TWITTER_USERNAME=
TWITTER_PASSWORD=

# Embeddings
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key

# RSSHub Integration
RSSHUB_URL=http://rsshub:1200
FINTWIT_TWITTER_HANDLES=elonmusk,cz_binance
FINTWIT_TELEGRAM_CHANNELS=
FINTWIT_SUBSTACK_URLS=

# Alert Thresholds
BTFD_PCT_DROP_THRESHOLD=-5.0
BTFD_VOLUME_RATIO_THRESHOLD=2.0
BTFD_MIN_MARKET_CAP=1000000000

# Portfolio Settings
BASE_CURRENCY=USD
DEFAULT_ACCOUNT=main
