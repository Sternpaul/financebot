{
  "manifest_version": 3,
  "name": "FinanceBot Twitter Scraper",
  "version": "1.0",
  "description": "Locally intercepts Twitter feeds and pushes to Supabase",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.twitter.com/*",
    "*://*.x.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"]
    }
  ]
}
