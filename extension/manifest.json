{
  "manifest_version": 3,
  "name": "FinanceBot Scraper",
  "version": "1.2",
  "description": "Omni-scraper for Twitter and all allowed domains.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "scrape-article": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Command+S"
      },
      "description": "Scrape the current article to FinanceBot"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://*.twitter.com/*", "*://*.x.com/*"]
    }
  ]
}
